meta {
  name: Log counter offer
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/offers
  body: json
  auth: none
}

headers {
  x-api-key: {{apiKey}}
  Content-Type: application/json
}

body:json {
  {
    "call_id": "{{callId}}",
    "load_id": "{{loadId}}",
    "carrier_mc": "{{mcNumber}}",
    "offered_rate": 2250
  }
}

docs {
  Same call_id, second round - triggers round-2 negotiation logic.
}
