{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "passThroughEnv": [
        "CONVEX_URL",
        "HAPPYROBOT_API_KEY",
        "BRIDGE_API_KEY",
        "ADMIN_API_KEY",
        "FMCSA_WEB_KEY"
      ]
    },
    "test:e2e": {
      "dependsOn": ["build"]
    }
  }
}
