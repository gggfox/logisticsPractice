{
  "name": "@carrier-sales/convex",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./convex/_generated/api": {
      "types": "./convex/_generated/api.d.ts",
      "default": "./convex/_generated/api.js"
    },
    "./convex/_generated/server": {
      "types": "./convex/_generated/server.d.ts",
      "default": "./convex/_generated/server.js"
    },
    "./convex/_generated/dataModel": {
      "types": "./convex/_generated/dataModel.d.ts"
    },
    "./convex/schema": "./convex/schema.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome check convex/",
    "dev": "npx convex dev --typecheck disable",
    "dev:codegen": "npx convex codegen --typecheck disable",
    "deploy": "npx convex deploy"
  },
  "dependencies": {
    "convex": "^1.17.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
