{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    "apps/api": {
      "entry": ["src/server.ts", "src/**/*.{test,spec}.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/dashboard": {
      "entry": [
        "src/main.tsx",
        "src/**/*.{test,spec}.{ts,tsx}",
        "playwright.config.ts",
        "e2e/**/*.ts"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/shared": {
      "entry": ["src/index.ts", "src/**/*.{test,spec}.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/convex": {
      "entry": ["convex/**/*.ts"],
      "project": ["convex/**/*.ts"],
      "ignore": ["convex/_generated/**"]
    }
  }
}
