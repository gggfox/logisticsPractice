# HappyRobot
HAPPYROBOT_API_KEY=your_happyrobot_api_key
HAPPYROBOT_BASE_URL=https://api.happyrobot.ai

# Bridge API Security
BRIDGE_API_KEY=your_bridge_api_key
ADMIN_API_KEY=your_admin_api_key
WEBHOOK_SECRET=your_webhook_hmac_secret

# FMCSA
FMCSA_WEB_KEY=your_fmcsa_web_key

# Convex
CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOY_KEY=your_convex_deploy_key

# Dashboard
# NOTE: VITE_CONVEX_URL is inlined at build time by Vite. In Dokploy it MUST be set
# as a Build Arg on the dashboard application (not a runtime Env), and changing it
# requires a Redeploy (rebuild), not just a restart. See docs/dokploy-setup.md.
VITE_CONVEX_URL=https://your-project.convex.cloud

# API runtime
HTTP_PORT=3111
STREAM_PORT=3112
DASHBOARD_ORIGIN=https://dashboard.example.com

# Redis (BullMQ). Required: apps/api/src/server.ts unconditionally boots
# workers that connect via ioredis.
#
# Values here are for host-native `pnpm dev`. When using `pnpm dev:all`
# (everything in Docker), docker-compose.dev.yml overrides this to
# `redis://redis:6379` via the container's environment block, so you
# don't need to edit this file to switch modes.
#
# In Dokploy this points at the shared redis service (redis://redis:6379).
REDIS_URL=redis://localhost:6379

# SigNoz stack (required when running `pnpm dev:all` or the SigNoz
# compose directly; the compose fails to parse without it). Generate a
# local value once with: openssl rand -base64 32
# In Dokploy, set this in the project Env tab instead.
SIGNOZ_JWT_SECRET=your_signoz_jwt_secret

# Observability (SigNoz via OTLP). See docs/observability.md and
# infra/dev/README.md.
#
# Values here are for host-native `pnpm dev`. When using `pnpm dev:all`,
# docker-compose.dev.yml overrides OTEL_EXPORTER_OTLP_ENDPOINT to the
# container-internal DNS name `http://signoz-otel-collector:4317` via
# the container's environment block, so no edit is needed to switch
# modes.
#
# For host-native dev: bring up the SigNoz stack with the dev overlay
# so the collector is reachable on the host:
#   docker compose \
#     -f infra/signoz/docker-compose.yml \
#     -f infra/signoz/docker-compose.dev.override.yml \
#     up -d
# then leave the endpoint at http://localhost:4317. If you don't want
# traces locally, flip OTEL_ENABLED=false -- flipping it true without a
# reachable collector floods logs with DNS / connection errors.
#
# In Dokploy / production, override in the Dokploy Env tab (NOT here):
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://signoz-otel-collector:4317
# `signoz-otel-collector` is the docker-network DNS for the collector in
# infra/signoz/docker-compose.yml and only resolves inside that network.
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=carrier-sales-api
SERVICE_VERSION=1.0.0
SERVICE_NAMESPACE=development
DEPLOYMENT_REGION=local

# Wide-event logging knobs (optional; sensible defaults baked in).
# WIDE_EVENT_SLOW_MS=2000
# WIDE_EVENT_SUCCESS_SAMPLE_RATE=1.0
# When true, an `x-debug: 1|true` request header forces wide-event emission
# regardless of success sampling. Leave false in production.
# DEBUG_HEADER_ENABLED=false
