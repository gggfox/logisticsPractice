# HappyRobot
HAPPYROBOT_API_KEY=your_happyrobot_api_key
HAPPYROBOT_BASE_URL=https://api.happyrobot.ai

# Bridge API Security
BRIDGE_API_KEY=your_bridge_api_key
ADMIN_API_KEY=your_admin_api_key
WEBHOOK_SECRET=your_webhook_hmac_secret

# FMCSA
FMCSA_WEB_KEY=your_fmcsa_web_key

# Convex
CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOY_KEY=your_convex_deploy_key

# Dashboard
# NOTE: VITE_CONVEX_URL is inlined at build time by Vite. In Dokploy it MUST be set
# as a Build Arg on the dashboard application (not a runtime Env), and changing it
# requires a Redeploy (rebuild), not just a restart. See docs/dokploy-setup.md.
VITE_CONVEX_URL=https://your-project.convex.cloud
