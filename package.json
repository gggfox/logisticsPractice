{
  "name": "inbound-carrier-sales",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:all": "docker compose -f docker-compose.dev.yml up --build",
    "dev:all:down": "docker compose -f docker-compose.dev.yml down",
    "dev:all:logs": "docker compose -f docker-compose.dev.yml logs -f api dashboard",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "analyze:complexity": "code-complexity . --limit 20 --sort score --filter '**/*,!**/_generated/**,!**/node_modules/**,!**/dist/**,!**/.turbo/**,!**/coverage/**,!pnpm-lock.yaml,!**/*.md,!**/*.yml,!**/*.yaml,!**/*.json,!**/*.http,!**/*.lock'",
    "analyze:duplication": "jscpd",
    "analyze:deadcode": "knip",
    "analyze": "pnpm analyze:complexity && pnpm analyze:duplication && pnpm analyze:deadcode",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@vitest/coverage-v8": "^3.0.0",
    "code-complexity": "^4.4.4",
    "husky": "^9.0.0",
    "jscpd": "^4.0.9",
    "knip": "^6.4.1",
    "lint-staged": "^15.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.7.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": ["biome check --write --no-errors-on-unmatched"]
  },
  "pnpm": {
    "overrides": {
      "protobufjs@<7.5.5": "^7.5.5"
    }
  }
}
